<!DOCTYPE html>
<html lang="en-GB">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tiger's Eyes Tattoos & Price Guide | Bespoke Designs, Cover-Ups — Telford & Wolverhampton</title>
<link rel="icon" href="favicon.ico" sizes="any">
<link rel="apple-touch-icon" href="favicon-180.png">
<meta name="theme-color" content="#c29a4b">
<meta name="description" content="Tiger's Eyes Tattoos — professional bespoke designs, two-part tattoos for you and a loved one, and cover-ups. Full price guide from £50. CPD certified, fully insured.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Great+Vibes&family=Jost:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body><header><nav class="nav" aria-label="Main navigation">
<a class="brand" href="index.html"><img src="{{ site.logo }}" alt="Tiger's Eyes logo"><span class="gold-text">Tiger's&nbsp;Eyes</span></a>
<button class="menu-btn" aria-label="Open menu" aria-expanded="false" onclick="toggleMenu(this)">☰</button>
<ul class="nav-links" id="navLinks"><li><a href="index.html">Home</a></li>
<li><a href="about.html">About</a></li>
<li><a href="microblading.html">Microblading</a></li>
<li><a href="artwork.html">Bespoke Artwork</a></li>
<li><a href="tattoos.html" class="active">Tattoos &amp; Prices</a></li>
<li><a href="contact.html">Contact</a></li>
<li><a class="nav-cta" href="contact.html">Book Now</a></li></ul>
</nav></header>
<main>
<div class="page-hero">
  <p class="eyebrow">Tiger's Eyes Tattoos</p>
  <h1>{{ tattoos.heading }}<span class="gold-text">{{ tattoos.headingGold }}</span></h1>
  <p class="sub">{{ tattoos.sub }}</p>
</div>
<div class="celestial" aria-hidden="true"><span class="line"></span>
<svg width="120" height="30" viewBox="0 0 120 30" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M60 2l1.8 5.2L67 9l-5.2 1.8L60 16l-1.8-5.2L53 9l5.2-1.8L60 2z" fill="#c29a4b"/>
<circle cx="38" cy="12" r="1.6" fill="#d8b46a"/><circle cx="82" cy="12" r="1.6" fill="#d8b46a"/>
<circle cx="24" cy="16" r="1" fill="#e9d9b4"/><circle cx="96" cy="16" r="1" fill="#e9d9b4"/>
<path d="M60 20a6 6 0 0 0 5 8 6.5 6.5 0 1 1-5-8z" fill="#c29a4b"/>
</svg><span class="line r"></span></div>
<section style="padding-top:56px">
  <div class="wrap" style="text-align:center">
    <p class="eyebrow">Client Results</p>
    <h2>{{ tattoos.galleryHeading }}</h2>
    <div class="g-grid">
      <figure class="g-item reveal"><div class="ph"><img src="{{ tattoos.gallery[0].image }}" alt="Butterfly and vine tattoo beside its original stencil design"></div><figcaption>{{ tattoos.gallery[0].caption }}</figcaption></figure>
      <figure class="g-item reveal"><div class="ph"><img src="{{ tattoos.gallery[1].image }}" alt="Butterfly tattoo with matching stencil on the arm"></div><figcaption>{{ tattoos.gallery[1].caption }}</figcaption></figure>
      <figure class="g-item reveal"><div class="ph"><img src="{{ tattoos.gallery[2].image }}" alt="Fine-line floral tattoo along the forearm"></div><figcaption>{{ tattoos.gallery[2].caption }}</figcaption></figure>
    </div>
    <div class="g-grid two">
      <figure class="g-item reveal"><div class="ph"><img src="{{ tattoos.gallery[3].image }}" alt="Two-part heart tattoo made of a loved one's name"></div><figcaption>{{ tattoos.gallery[3].caption }}</figcaption></figure>
      <figure class="g-item reveal"><div class="ph"><img src="{{ tattoos.gallery[4].image }}" alt="Cover-up tattoo on the forearm"></div><figcaption>{{ tattoos.gallery[4].caption }}</figcaption></figure>
    </div>
    <div class="note-strip reveal" style="text-align:left"><b>Every tattoo includes:</b> {{ tattoos.note }}</div>
  </div>
</section>
<section class="cred" style="padding-top:70px;padding-bottom:80px">
  <div class="wrap">
    <div style="text-align:center">
      <p class="eyebrow">Tiger's Eyes Studio</p>
      <h2>{{ tattoos.priceHeading }}</h2>
      <p style="margin:18px 0 30px;color:var(--muted)">{{ tattoos.priceIntro }}</p>
      <span class="min-charge reveal">{{ tattoos.minCharge }}</span>
    </div>
    <table class="price-table reveal">
      <thead><tr><th>Tattoo</th><th>Price</th><th>Details</th></tr></thead>
      <tbody>
        <tr><td><b>{{ tattoos.rows[0].name }}</b> {{ tattoos.rows[0].meta }}</td><td class="amt">{{ tattoos.rows[0].price }}</td><td>{{ tattoos.rows[0].detail }}</td></tr>
        <tr><td><b>{{ tattoos.rows[1].name }}</b> {{ tattoos.rows[1].meta }}</td><td class="amt">{{ tattoos.rows[1].price }}</td><td>{{ tattoos.rows[1].detail }}</td></tr>
        <tr><td><b>{{ tattoos.rows[2].name }}</b> {{ tattoos.rows[2].meta }}</td><td class="amt">{{ tattoos.rows[2].price }}</td><td>{{ tattoos.rows[2].detail }}</td></tr>
        <tr><td><b>{{ tattoos.rows[3].name }}</b> {{ tattoos.rows[3].meta }}</td><td class="amt">{{ tattoos.rows[3].price }}</td><td>{{ tattoos.rows[3].detail }}</td></tr>
        <tr><td><b>{{ tattoos.rows[4].name }}</b> {{ tattoos.rows[4].meta }}</td><td class="amt">{{ tattoos.rows[4].price }}</td><td>{{ tattoos.rows[4].detail }}</td></tr>
      </tbody>
    </table>
    <div class="note-strip reveal"><b>Deposits:</b> {{ tattoos.deposits }} <i>{{ tattoos.depositsNote }}</i></div>
  </div>
</section>
</main>
<div class="cta-band">
  <span class="script gold-text" style="-webkit-text-fill-color:initial;color:var(--gold-deep)">{{ site.ctaScript }}</span>
  <p>{{ site.ctaSub }}</p>
  <a class="btn btn-gold" href="contact.html">{{ site.ctaButton }}</a>
</div>
<footer><div class="wrap">
  <div class="f-brand"><img src="{{ site.logo }}" alt=""><div>{{ site.footerLine | safe }}</div></div>
  <div><a href="tel:{{ site.phoneLink }}">{{ site.phone }}</a><br><a href="mailto:{{ site.email }}">{{ site.email }}</a></div>
  <nav aria-label="Footer"><a href="about.html">About</a><a href="microblading.html">Microblading</a><a href="artwork.html">Artwork</a><a href="tattoos.html">Tattoos</a><a href="contact.html">Book Now</a></nav>
</div></footer>
<script>
function toggleMenu(btn){const l=document.getElementById('navLinks');const o=l.classList.toggle('open');btn.setAttribute('aria-expanded',o);}
if('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches){
  const io=new IntersectionObserver(es=>es.forEach(en=>{if(en.isIntersecting){en.target.classList.add('in');io.unobserve(en.target);}}),{threshold:.1});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
}else{document.querySelectorAll('.reveal').forEach(el=>el.classList.add('in'));}
</script>
</body></html>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Great+Vibes&family=Jost:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body><header><nav class="nav" aria-label="Main navigation">
<a class="brand" href="index.html"><img src="/images/tiger-s-eyes-logo-431ec7f0.webp" alt="Tiger's Eyes logo"><span class="gold-text">Tiger's&nbsp;Eyes</span></a>
<button class="menu-btn" aria-label="Open menu" aria-expanded="false" onclick="toggleMenu(this)">☰</button>
<ul class="nav-links" id="navLinks"><li><a href="index.html" class="active">Home</a></li>
<li><a href="about.html">About</a></li>
<li><a href="microblading.html">Microblading</a></li>
<li><a href="artwork.html">Bespoke Artwork</a></li>
<li><a href="tattoos.html">Tattoos &amp; Prices</a></li>
<li><a href="contact.html">Contact</a></li>
<li><a class="nav-cta" href="contact.html">Book Now</a></li></ul>
</nav></header>
<main>
<section class="hero">
  <img class="logo-lg" src="/images/tiger-s-eyes-logo-431ec7f0.webp" alt="Tiger's Eyes — golden eye emblem">
  <h1>{{ home.heroHeadline | safe }}<span class="gold-text">{{ home.heroHeadlineGold | safe }}</span></h1>
  <p class="script-line">{{ home.heroScript }}</p>
  <p class="sub">{{ home.heroIntro }}</p>
  <div class="hero-ctas">
    <a class="btn btn-gold" href="contact.html">Book a Consultation</a>
    <a class="btn btn-line" href="about.html">Meet Louise</a>
  </div>
  <div class="badges">
    <span><b>CPD</b> Certified Artist</span><span><b>Fully</b> Insured</span>
    <span><b>3</b> Studio Locations</span><span><b>UK</b> Hygiene Compliant</span>
  </div>
</section>
<div class="celestial" aria-hidden="true"><span class="line"></span>
<svg width="120" height="30" viewBox="0 0 120 30" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M60 2l1.8 5.2L67 9l-5.2 1.8L60 16l-1.8-5.2L53 9l5.2-1.8L60 2z" fill="#c29a4b"/>
<circle cx="38" cy="12" r="1.6" fill="#d8b46a"/><circle cx="82" cy="12" r="1.6" fill="#d8b46a"/>
<circle cx="24" cy="16" r="1" fill="#e9d9b4"/><circle cx="96" cy="16" r="1" fill="#e9d9b4"/>
<path d="M60 20a6 6 0 0 0 5 8 6.5 6.5 0 1 1-5-8z" fill="#c29a4b"/>
</svg><span class="line r"></span></div>
<section>
  <div class="wrap" style="text-align:center">
    <p class="eyebrow">Discover Tiger's Eyes</p>
    <h2 style="font-size:clamp(1.9rem,4vw,2.6rem)">{{ home.servicesHeading }}</h2>
    <p style="max-width:66ch;margin:16px auto 0;color:var(--muted)">{{ home.servicesIntro }}</p>
    <div class="svc-grid">
      <article class="svc-card reveal">
        <div class="ph"><img src="/images/microblading-client-result-bespoke-brow--10814a6f.webp" alt="Microblading client result — bespoke brow shaping"></div>
        <div class="body">
          <h3>{{ home.cards[0].title }}</h3>
          <p class="from">{{ home.cards[0].price }}</p>
          <p>{{ home.cards[0].text }}</p>
          <a class="btn btn-line" href="microblading.html">Explore</a>
        </div>
      </article>
      <article class="svc-card reveal">
        <div class="ph"><img src="/images/framed-bespoke-bee-artwork-with-personal-84069323.webp" alt="Framed bespoke bee artwork with personalised words"></div>
        <div class="body">
          <h3>{{ home.cards[1].title }}</h3>
          <p class="from">{{ home.cards[1].price }}</p>
          <p>{{ home.cards[1].text }}</p>
          <a class="btn btn-line" href="artwork.html">Explore</a>
        </div>
      </article>
      <article class="svc-card reveal">
        <div class="ph"><img src="/images/fine-line-floral-tattoo-on-forearm-c7faa40c.webp" alt="Fine-line floral tattoo on forearm"></div>
        <div class="body">
          <h3>{{ home.cards[2].title }}</h3>
          <p class="from">{{ home.cards[2].price }}</p>
          <p>{{ home.cards[2].text }}</p>
          <a class="btn btn-line" href="tattoos.html">Explore</a>
        </div>
      </article>
    </div>
  </div>
</section>
<section class="cred">
  <div class="wrap">
    <h2>{{ home.meetHeading }}</h2>
    <p class="sub">{{ home.meetSub }}</p>
    <div class="duo duo-about">
      <figure class="portrait reveal">
        <img src="{{ home.portrait }}" alt="Louise Curel, business owner and artistic director at Tiger's Eyes">
        <figcaption>Louise Curel</figcaption>
      </figure>
      <div class="prose reveal">
        <p>{{ home.meetText1 }}</p>
        <p>{{ home.meetText2 }}</p>
        <a class="btn btn-line" href="about.html" style="margin-top:8px">Read Louise's Full Story</a>
      </div>
    </div>
  </div>
</section>
</main>
<div class="cta-band">
  <span class="script gold-text" style="-webkit-text-fill-color:initial;color:var(--gold-deep)">{{ site.ctaScript }}</span>
  <p>{{ site.ctaSub }}</p>
  <a class="btn btn-gold" href="contact.html">{{ site.ctaButton }}</a>
</div>
<footer><div class="wrap">
  <div class="f-brand"><img src="/images/tiger-s-eyes-logo-431ec7f0.webp" alt=""><div>{{ site.footerLine | safe }}</div></div>
  <div><a href="tel:{{ site.phoneLink }}">{{ site.phone }}</a><br><a href="mailto:{{ site.email }}">{{ site.email }}</a></div>
  <nav aria-label="Footer"><a href="about.html">About</a><a href="microblading.html">Microblading</a><a href="artwork.html">Artwork</a><a href="tattoos.html">Tattoos</a><a href="contact.html">Book Now</a></nav>
</div></footer>
<script>
function toggleMenu(btn){const l=document.getElementById('navLinks');const o=l.classList.toggle('open');btn.setAttribute('aria-expanded',o);}
if('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches){
  const io=new IntersectionObserver(es=>es.forEach(en=>{if(en.isIntersecting){en.target.classList.add('in');io.unobserve(en.target);}}),{threshold:.1});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
}else{document.querySelectorAll('.reveal').forEach(el=>el.classList.add('in'));}
</script>
</body></html>